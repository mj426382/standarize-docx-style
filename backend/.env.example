# Baza danych
DATABASE_URL="postgresql://dokformat:dokformat@localhost:5432/dokformat?schema=public"

# JWT
JWT_SECRET="zmien-mnie-na-dlugi-losowy-sekret"
JWT_EXPIRES_IN="7d"

# OpenAI
OPENAI_API_KEY="sk-..."

# Google OAuth
GOOGLE_CLIENT_ID="...apps.googleusercontent.com"

# Storage Backblaze B2 (S3-compatible). Puste => fallback na dysk lokalny /app/uploads
B2_ENDPOINT=""
B2_BUCKET_NAME=""
B2_KEY_ID=""
B2_APPLICATION_KEY=""
B2_REGION="eu-central-003"
B2_PUBLIC_URL=""

# Aplikacja
FRONTEND_URL="http://localhost:5173"
PORT="3026"

# Tryb testów E2E - deterministyczny adapter LLM (bez realnych wywołań OpenAI)
E2E="false"
